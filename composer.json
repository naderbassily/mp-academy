{
    "name": "mp-academy/theme",
    "type": "wordpress-theme",
    "description": "MP Academy WordPress theme for LearnDash and the Franklin Design System.",
    "keywords": [
        "WordPress",
        "Themes"
    ],
    "homepage": "https://github.com/naderbassily/mp-academy",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "MP Academy Team",
            "homepage": "https://github.com/naderbassily/mp-academy/graphs/contributors"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^0.7.0",
        "wptrt/wpthemereview": "^0.2.1",
        "php-parallel-lint/php-parallel-lint": "^1.2.0",
        "wp-cli/i18n-command": "^2.2.5"
    },
    "scripts": {
        "lint:wpcs": "@php ./vendor/squizlabs/php_codesniffer/bin/phpcs",
        "lint:php": "@php ./vendor/bin/parallel-lint --exclude .git --exclude vendor .",
        "make-pot": "wp i18n make-pot . languages/mp-academy.pot"
    },
    "support": {
        "issues": "https://github.com/naderbassily/mp-academy/issues",
        "source": "https://github.com/naderbassily/mp-academy"
    }
}
